{
    "name": "@noxfly/noxus",
    "version": "3.0.0",
    "author": "NoxFly",
    "license": "MIT",
    "description": "Lightweight HTTP-like IPC framework for Electron with standalone controllers, explicit DI, and lazy route loading. No reflect-metadata required.",
    "homepage": "https://github.com/NoxFly/noxus",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/NoxFly/noxus.git"
    },
    "files": [
        "dist"
    ],
    "main": "dist/main.js",
    "module": "dist/main.mjs",
    "types": "dist/main.d.ts",
    "exports": {
        ".": {
            "browser": {
                "types": "./dist/renderer.d.ts",
                "import": "./dist/renderer.mjs",
                "require": "./dist/renderer.js"
            },
            "default": {
                "types": "./dist/child.d.ts",
                "import": "./dist/child.mjs",
                "require": "./dist/child.js"
            }
        },
        "./main": {
            "types": "./dist/main.d.ts",
            "import": "./dist/main.mjs",
            "require": "./dist/main.js"
        },
        "./renderer": {
            "types": "./dist/renderer.d.ts",
            "import": "./dist/renderer.mjs",
            "require": "./dist/renderer.js"
        },
        "./preload": {
            "types": "./dist/preload.d.ts",
            "import": "./dist/preload.mjs",
            "require": "./dist/preload.js"
        },
        "./child": {
            "types": "./dist/child.d.ts",
            "import": "./dist/child.mjs",
            "require": "./dist/child.js"
        }
    },
    "typesVersions": {
        "*": {
            "main": [
                "./dist/main.d.ts"
            ],
            "renderer": [
                "./dist/renderer.d.ts"
            ],
            "preload": [
                "./dist/preload.d.ts"
            ],
            "child": [
                "./dist/child.d.ts"
            ]
        }
    },
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "npm run build",
        "prepush": "npm run build",
        "postbuild": "node scripts/postbuild.js"
    },
    "keywords": [
        "noxus",
        "nox",
        "nodejs",
        "typescript",
        "framework",
        "electron",
        "ipc",
        "dependency-injection",
        "standalone",
        "lazy-loading"
    ],
    "engines": {
        "node": ">= 22"
    },
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@swc/core": "^1.15.43",
        "electron": "^43.1.1",
        "tsc-alias": "^1.9.1",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    }
}
